{
  "permissions": {
    "allow": [
      "Bash(./.claude/skills/codex-review/scripts/run_codex_review.sh:*)",
      "Bash(.claude/skills/codex-review/scripts/run_codex_review.sh:*)",
      "Bash(git diff:*)",
      "Bash(npm --prefix packages/web run test:*)",
      "Bash(npm --prefix packages/web run lint:*)",
      "Bash(.venv/bin/pytest:*)",
      "Bash(.venv/bin/ruff check:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      { "hooks": [ { "type": "command", "command": "./.claude/hooks/session_start.sh" } ] }
    ],
    "Stop": [
      { "hooks": [ { "type": "command", "command": "./.claude/hooks/log_turn.sh" } ] }
    ]
  }
}
