# OCI 環境依存値の雛形。実値は .env に置く（コミット禁止）
OCI_REGION=ap-osaka-1
COMPARTMENT_OCID=ocid1.compartment.oc1..xxxxxxxx
OS_NAMESPACE=your-object-storage-namespace

# OpenAI互換エンドポイント（リージョンから導出可能だが明示）
GENAI_BASE_URL=https://inference.generativeai.ap-osaka-1.oci.oraclecloud.com/openai/v1

# SPIKE-04 (ADB)
ADB_ADMIN_PASSWORD=
ADB_OCID=
# アプリ/読取スキーマ（開発者ごとにE2E環境を分ける場合に上書き。既定は共有スキーマ）
# 例: ADB_USER=JETUSE_ALICE / ADB_QUERY_USER=JETUSE_ALICE_Q（ops/setup-dev-schema.py で作成）
ADB_USER=JETUSE_APP
ADB_QUERY_USER=JETUSE_QUERY
# SBA-B(SBA-03) NL2SQL の照会対象スキーマ。設定すると専用 execute が実行接続の CURRENT_SCHEMA を
# この値へ固定し、非修飾テーブル名を当該スキーマの物理表へ確定解決する。空なら既定解決。
SAMPLE_DB_SCHEMA=

# SPIKE-02 (SSE)
APIGW_ENDPOINT=

# INFRA-02 (OIDC / 専用Identity Domain)
AUTH_REQUIRED=false
OIDC_ISSUER=https://identity.oraclecloud.com/
OIDC_JWKS_URL=https://idcs-xxxxxxxx.identity.oraclecloud.com/admin/v1/SigningCert/jwk

# VOICE-01 (議事録): 音声・文字起こし結果のバケット(空なら機能無効)
SPEECH_BUCKET=jetuse-dev-speech

# BE-08 認証付き MCP 登録: 資格情報を束ねる Vault と暗号鍵。3 値すべて設定 + IAM(use keys/
# use vaults/manage secret-family。docs/setup/iam.md)で認証付き登録が有効化。空なら 503(fail-closed)。
# 既存リソースを参照する(OCID 実値はコミットしない)。COMPARTMENT_OCID を流用。
VAULT_OCID=            # ocid1.vault.oc1...（secret を作成する Vault コンテナ）
VAULT_KEY_OCID=        # ocid1.key.oc1...（secret 内容の暗号化に使う KMS 鍵）

# PLG-03 取込: 中央レジストリ index.json のベースURL(空なら取込機能無効)
PLUGIN_REGISTRY_URL=

# PLG-05 公開(発行者として中央レジストリへ publish)。いずれか空なら publish=無効(503)。
# 実値は .env / Vault に置きコミットしない(鍵・トークンの混入防止)。
REGISTRY_PUBLISH_URL=            # publish API のベースURL 例 https://registry.example
REGISTRY_PUBLISHER_ID=          # 発行者ID(manifest.publisher / レジストリ認証と対応)
REGISTRY_PUBLISHER_TOKEN=       # publish 用 Bearer トークン(平文)
REGISTRY_SIGNING_KEY=           # base64(32バイト ed25519 秘密シード)。manifest 署名鍵
REGISTRY_PUBLIC_KEY_ID=         # 署名鍵に対応する公開鍵ID(レジストリ登録名)
REGISTRY_NAMESPACE=             # plugin id の名前空間(空なら REGISTRY_PUBLISHER_ID)
