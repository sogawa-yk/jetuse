# OCI 環境依存値の雛形。実値は .env に置く（コミット禁止）
OCI_REGION=ap-osaka-1
COMPARTMENT_OCID=ocid1.compartment.oc1..xxxxxxxx
OS_NAMESPACE=your-object-storage-namespace

# OpenAI互換エンドポイント（リージョンから導出可能だが明示）
GENAI_BASE_URL=https://inference.generativeai.ap-osaka-1.oci.oraclecloud.com/openai/v1

# SPIKE-04 (ADB)
ADB_ADMIN_PASSWORD=
ADB_OCID=
# アプリ/読取スキーマ（開発者ごとにE2E環境を分ける場合に上書き。既定は共有スキーマ）
# 例: ADB_USER=JETUSE_ALICE / ADB_QUERY_USER=JETUSE_ALICE_Q（ops/setup-dev-schema.py で作成）
ADB_USER=JETUSE_APP
ADB_QUERY_USER=JETUSE_QUERY

# SPIKE-02 (SSE)
APIGW_ENDPOINT=

# INFRA-02/SP2-04 (OIDC / 専用Identity Domain)。AUTH_REQUIRED=true では3値全て必須(不備は500)。
# issuer/JWKS は当該ドメインの discovery(<domain_url>/.well-known/openid-configuration)の値を
# そのまま使う(issuer は IdP 世代で異なるため固定値を書かない — specs/18 §5.1)。
# audience は discovery からは得られない: アプリ登録の primary audience か実トークンの aud 実測値。
AUTH_REQUIRED=false
OIDC_ISSUER=<discoveryのissuerをそのまま>
OIDC_JWKS_URL=<discoveryのjwks_uriをそのまま>
OIDC_AUDIENCE=<アプリ登録のprimary audience または実トークンのaud実測値>
# SP3-03 (ADR-0023 §3.5): 生成 SPA の app-session Cookie/一回性コードの HMAC 秘密鍵。
# AUTH_REQUIRED=true の配信で必須(空なら Cookie 認証経路は fail-closed で無効)。ランダムな長い値。
APP_SESSION_SECRET=<openssl rand -hex 32 などの高エントロピー値・コミットしない>

# VOICE-01 (議事録): 音声・文字起こし結果のバケット(空なら機能無効)
SPEECH_BUCKET=jetuse-dev-speech

# SP2-02 (箱ライフサイクル / specs/18): RAG 上限
# demo 箱あたりのファイル数上限(既定 20)
DEMO_MAX_RAG_FILES=20
# アプリ全体の Files 総数上限。未設定=無効(挙動不変)。Internal 配備でテナンシ File 枠を守る
# ときだけ下行のコメントを外して正の整数を設定する(予約 ledger の reserve が超過で 422 を返す)。
# 注意: 空文字 `RAG_FILES_TOTAL_LIMIT=` は int|None 検証に失敗し起動不能 — 無効化は「行ごと省略」。
# RAG_FILES_TOTAL_LIMIT=2000
# VPD(行レベル分離)。既定 false=Public/従来互換(未配備環境で dataset/dbchat が壊れない)。
# Internal/デモテナンシ配備のみ true(人間ゲートで VPD セットアップ済みが前提)。
VPD_ENABLED=false

# SP3-03: 生成コンテナ(鍵レス)から見た署名プロキシの実エンドポイント(必須・環境依存)。
# 例: rootless podman(slirp4netns)なら host gateway。値はコードにコミットしない。
GENERATION_PROXY_URL=http://<proxy-host-as-seen-from-container>:8765/v1

# SP3-06: 生成 gpt-5 系(共有テナンシ)の OCI CLI auth プロファイルと compartment OCID。
# 空 = 共有テナンシモデルは使用不可(fail-closed: プロキシ 403 / runtime は起動前に明示失敗)。
# 実行・課金は共有テナンシ側(docs/verification/SP3-06.md)。値はコミット禁止。
GEN_SHARED_PROFILE=<~/.oci/config のプロファイル名>
GEN_SHARED_COMPARTMENT_OCID=ocid1.compartment.oc1..xxxxxxxx
