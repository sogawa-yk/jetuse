{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jetuse.oracle.com/schemas/experience-builder/answer-with-citations.output.schema.json",
  "title": "answer.with-citations@1 outputSchema",
  "description": "完了時の出力 (実装方針 §7.1)。引用付き回答。",
  "type": "object",
  "required": ["answer", "citations"],
  "additionalProperties": false,
  "properties": {
    "answer": { "type": "string" },
    "citations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source"],
        "additionalProperties": true,
        "properties": {
          "source": { "type": "string", "minLength": 1 },
          "score": { "type": "number" },
          "snippet": { "type": "string" }
        }
      }
    }
  }
}
