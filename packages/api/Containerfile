# ビルドコンテキストはリポジトリルート(jetuse_shared が api の外にあるため。P1bで共有化)。
#   podman build -f packages/api/Containerfile -t <image> .
FROM docker.io/library/python:3.12-slim
WORKDIR /app
# 共有ロジック(SSRFガード/Webツール/SQLサニタイズ)を pyproject の file:../jetuse_shared が
# 解決できる位置(/jetuse_shared = WORKDIR の ../jetuse_shared)へ先に配置する。
COPY packages/jetuse_shared /jetuse_shared
COPY packages/api/pyproject.toml ./
COPY packages/api/jetuse_core ./jetuse_core
COPY packages/api/service ./service
COPY packages/api/fn ./fn
COPY packages/api/entrypoint.sh ./entrypoint.sh
RUN pip install --no-cache-dir . uvicorn && chmod +x entrypoint.sh
# 非 root で実行する(OKE の runAsNonRoot/runAsUser=10001 と整合。ADR-0017)。/app は読み取りのみ。
RUN useradd -u 10001 -m appuser && chown -R 10001:10001 /app
USER 10001
EXPOSE 8000
# RUN_DB_BOOTSTRAP=true で起動時にスキーマ用意+マイグレーション(ORMワンクリック)。既定はuvicornのみ。
CMD ["./entrypoint.sh"]
