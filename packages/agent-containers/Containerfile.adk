# ビルドコンテキストはリポジトリルート(jetuse_shared が agent-containers の外にあるため)。
#   podman build -f packages/agent-containers/Containerfile.adk -t jetuse-agent-adk .
# まとめてビルドするには packages/agent-containers/build.sh を使う。
FROM python:3.12-slim
WORKDIR /app
COPY packages/agent-containers/requirements-adk.txt ./requirements.txt
RUN pip install --no-cache-dir -r requirements.txt
# 共有のセキュリティ要件ロジック(SSRFガード/Webツール/SQLサニタイズ)を pip 取り込み(P1b)
COPY packages/jetuse_shared ./jetuse_shared
RUN pip install --no-cache-dir ./jetuse_shared
COPY packages/agent-containers/agent_common.py packages/agent-containers/agent_db.py \
     packages/agent-containers/server.py packages/agent-containers/run_adk.py ./
EXPOSE 8080
CMD ["uvicorn", "run_adk:app", "--host", "0.0.0.0", "--port", "8080"]
