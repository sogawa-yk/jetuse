# 実値は terraform.tfvars に置く(コミット禁止)。.env と同期すること
tenancy_ocid       = "ocid1.tenancy.oc1..xxxxxxxx"
compartment_ocid   = "ocid1.compartment.oc1..xxxxxxxx"
prefix             = "jetuse-dev"
adb_admin_password = "change-me"

# 初回applyではOCIRが空のためCIなし。イメージpush後に設定して再apply
# api_image_url        = "kix.ocir.io/<namespace>/jetuse-dev-api:latest"
# image_pull_secret_id = "ocid1.vaultsecret.oc1..xxxxxxxx"

# APP-01でFunctionsをデプロイ後に追加
# functions_routes = {
#   conversations = "ocid1.fnfunc.oc1..xxxxxxxx"
# }

# IAMは動的グループ(テナンシ権限)とランタイムポリシー(コンパートメント権限)を個別管理できる。
# 既存IAMを使う環境では両方falseのままにする。
# enable_dynamic_group  = false
# enable_runtime_policy = false

# SP2-04: Internal(jetuse-dev)配備は AUTH_REQUIRED=true が既定(main.tf locals)。
# OIDC 実値(人間が Identity Domain アプリ登録から受領。コミット禁止)をここに投入する。
# AUTH_REQUIRED=true では3値全て必須(不備は API が 500 を返す fail-closed)。
# api_environment = {
#   OIDC_ISSUER   = "<discovery の issuer をそのまま>"
#   OIDC_JWKS_URL = "<discovery の jwks_uri をそのまま>"
#   OIDC_AUDIENCE = "<アプリ登録の primary audience または実トークンの aud 実測値>"
# }
