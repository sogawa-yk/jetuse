# 相2 信頼ビルドイメージ(SP3-08 / ADR-0023 §1: node:22-slim + vendored scaffold。
# OpenCode/LLM 非搭載)。node_modules は lockfile 固定でイメージビルド時に焼き込み、
# 実行時は npm 解決を一切しない(ADR §3 C1)。ビルドコンテキストはリポジトリルート:
#   podman build -f infra/images/gen-ci/Containerfile.build -t <ocir>/jetuse-dev-build:<tag> .
FROM node:22-slim@sha256:a149cd71dccd68704a07d4e4ca3e610c27301852b0f556865cfdb6e2856f8bed
COPY infra/images/gen-ci/xfer.mjs infra/images/gen-ci/run-build.sh /usr/local/bin/
COPY spikes/sp3_03_scaffold /scaffold
RUN rm -rf /scaffold/node_modules /scaffold/dist \
 && cd /scaffold && npm ci --no-audit --no-fund \
 && chmod +x /usr/local/bin/run-build.sh
CMD ["/usr/local/bin/run-build.sh"]
