# 相1 生成イメージ(SP3-08 / ADR-0023 §1: node:22-slim + OpenCode + vendored scaffold)。
# ビルドコンテキストはリポジトリルート:
#   podman build -f infra/images/gen-ci/Containerfile.gen -t <ocir>/jetuse-dev-gen:<tag> .
# OCIR public repo へ push(CI が匿名 pull — ADR-0011。イメージに秘密は含まれない)。
FROM node:22-slim@sha256:a149cd71dccd68704a07d4e4ca3e610c27301852b0f556865cfdb6e2856f8bed
RUN npm i -g opencode-ai@1.17.15
COPY infra/images/gen-ci/xfer.mjs infra/images/gen-ci/run-gen.sh /usr/local/bin/
COPY spikes/sp3_03_scaffold /scaffold
# 生成相は build-free(src のみ編集)— node_modules/dist は載せない
RUN rm -rf /scaffold/node_modules /scaffold/dist && chmod +x /usr/local/bin/run-gen.sh
# @ai-sdk/openai(responses 系 provider)を事前導入(実行時 npm 取得の排除 — SP3-06 residual)。
# opencode は provider npm を $HOME/.cache/opencode/packages/<name>@<ver> へ入れる(実測)。
# 到達不能な baseURL でダミー実行して導入だけ済ませ(LLM 待ちで固まるため kill)、
# 導入されたことを test で fail-closed 確認。
COPY infra/images/gen-ci/prewarm.json /gen-home/prewarm/opencode.json
RUN cd /gen-home/prewarm \
 && HOME=/gen-home timeout -s KILL 180 opencode run --model oci/prewarm "prewarm" || true; \
    test -d "/gen-home/.cache/opencode/packages/@ai-sdk/openai@4.0.9" \
 && rm -rf /gen-home/prewarm
CMD ["/usr/local/bin/run-gen.sh"]
